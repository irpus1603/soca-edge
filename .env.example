# ── soca-edge — Environment Variables ────────────────────────────────────────
# Repo: soca-edge  (soca-engine + soca-dashboard)
# Copy to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── Edge Identity ─────────────────────────────────────────────────────────────
# Unique name for this edge device. Also used as GCS path prefix automatically.
EDGE_NAME=edge-01


# ── soca-engine API Key ───────────────────────────────────────────────────────
# Used by soca-dashboard to authenticate against soca-engine.
# Generate: python -c "import secrets; print(secrets.token_hex(16))"
ENGINE_API_KEY=


# ── Alert Transport ───────────────────────────────────────────────────────────
# redis   → simple, self-hosted (default)
# pubsub  → Google Cloud Pub/Sub
PUBLISHER_TYPE=redis

# Redis stream name (PUBLISHER_TYPE=redis only)
REDIS_STREAM_NAME=soca:detections

# Google Pub/Sub settings (PUBLISHER_TYPE=pubsub only)
PUBSUB_PROJECT_ID=
PUBSUB_TOPIC=soca-detections
PUBSUB_KEY_PATH=


# ── Google Cloud Storage — Snapshot Upload ────────────────────────────────────
# Leave blank to keep snapshots local only (no GCS upload)
GCS_BUCKET=
GCS_KEY_PATH=
GCS_PATH_PREFIX=    # Defaults to EDGE_NAME when blank


# ── Inference ─────────────────────────────────────────────────────────────────
INFER_DEVICE=cpu    # cpu | cuda:0 (GPU requires NVIDIA Container Toolkit)
INFER_IMGSZ=640
MAX_CONCURRENT_JOBS=4
MAX_LOADED_MODELS=3
SNAPSHOT_JPEG_QUALITY=60
SNAPSHOT_MAX_WIDTH=1280
LOG_LEVEL=INFO


# ── soca-dashboard (Django) ───────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
DASHBOARD_SECRET_KEY=

DASHBOARD_DEBUG=false
DASHBOARD_ALLOWED_HOSTS=*
